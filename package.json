{
  "name": "DCC-PPT-Generator",
  "version": "1.0.0",
  "description": "DCC Bulletin to PowerPoint Generator",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-packager . --executable-name=\"DCC PPT Generator\" --platform=win32 --arch=x64 --icon=DCC.ico --out=dist --overwrite --ignore=\"^/dist\"",
    "zip:win": "pushd dist && powershell Compress-Archive DCC-PPT-Generator-win32-x64 DCC-PPT-Generator-win32-x64.zip -Force && popd",
    "WINDOWS_NO_LIKEY_GIT_TAR_______zip:win": "tar -acf \"dist/DCC PPT Generator-win32-x64.zip\" \"dist/DCC PPT Generator-win32-x64\"",
    "cli": "node src/cli.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "ajv": "^8.18.0",
    "cheerio": "^1.0.0",
    "electron-store": "^8.2.0",
    "fuse.js": "^7.0.0",
    "lucide": "^0.577.0",
    "mammoth": "^1.8.0",
    "underscore": "^1.13.6"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^33.4.11"
  }
}
